rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['username']);
    }

    function isValidLog(data) {
      return data.keys().hasAll(['type', 'title']);
    }

    match /users/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());

      match /logs/{logId} {
        allow list, get: if true;
        allow create: if isOwner(userId)
                    && isValidLog(incoming())
                    && exists(/databases/$(database)/documents/users/$(userId));
        // Logs shouldn't be updated or deleted natively by the client
        allow update, delete: if false;
      }
    }

    match /logs/{logId} {
      allow list, get: if true;
      allow create, update, delete: if false;
    }
  }
}
