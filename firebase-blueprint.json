{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balances",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "avatar": { "type": "string" },
        "tonBalance": { "type": "number" },
        "gqhBalance": { "type": "number" },
        "walletAddress": { "type": ["string", "null"] },
        "referralCount": { "type": "number" },
        "referralEarnings": { "type": "number" },
        "hasClaimedWelcomeBonus": { "type": "boolean" },
        "telegramJoined": { "type": "boolean" },
        "dailyClaimedAt": { "type": ["string", "null"] },
        "adCooldownSeconds": { "type": "number" },
        "hapticEnabled": { "type": "boolean" },
        "soundEnabled": { "type": "boolean" },
        "completedTasksCount": { "type": "number" },
        "watchedAdsCount": { "type": "number" },
        "dailyCheckInCount": { "type": "number" },
        "telegramTasksCount": { "type": "number" },
        "airdropRegistered": { "type": "boolean" },
        "airdropSignatureStatus": { "type": "string" },
        "miningEnergy": { "type": "number" }
      },
      "required": ["username"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Log of user activity",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "title": { "type": "string" },
        "amount": { "type": "string" },
        "token": { "type": "string" },
        "timestamp": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["type", "title", "amount", "token", "timestamp"]
    },
    "CustomTask": {
      "title": "CustomTask",
      "description": "User created promoted task",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "link": { "type": "string" },
        "maxClicks": { "type": "number" },
        "currentClicks": { "type": "number" },
        "creatorId": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["title", "description", "link", "maxClicks", "currentClicks", "creatorId", "status", "createdAt"]
    },
    "UserTaskMapping": {
      "title": "UserTaskMapping",
      "description": "Record of a user completing a task",
      "type": "object",
      "properties": {
        "completedAt": { "type": "number" }
      },
      "required": ["completedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Contains user data"
    },
    "users/{userId}/logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Contains user activity logs"
    },
    "users/{userId}/completedTasks/{taskId}": {
      "schema": "UserTaskMapping",
      "description": "Completed custom tasks"
    },
    "customTasks/{taskId}": {
      "schema": "CustomTask",
      "description": "Global custom tasks created by users"
    }
  }
}
